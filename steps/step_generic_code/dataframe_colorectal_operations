def get_all_features(app):
    result = app.session.query(HFT_TREATMENT_T.treatment_id, HFT_TREATMENT_T.age, HFT_TREATMENT_T.gender)\
                        .join(PATIENT_DERIVED,PATIENT_DERIVED.treatment_id==HFT_TREATMENT_T.treatment_id)\
                        .filter(PATIENT_DERIVED.use_for_model==True).all()
    features_df = pd.DataFrame([row for row in result], columns=['treatment_id', 'age', 'gender'])
    return features_df

